(declare-const g:PrincipalType String)
(declare-const g:PrincipalID String)
(declare-const g:Action String)
(declare-const g:Effect String)
(declare-const g:Condition String)
(declare-const g:PrincipalTypeValue String)
(declare-const g:ActionValue String)
(declare-const g:EffectValue String)
(declare-const g:PrincipalIDValue String)
(declare-const g:ConditionValue String)
(declare-const g:Statement (Array String (Array String String)))
(declare-const g:BucketPolicy (Array String (Array String String)))
(declare-const g:BucketName String)
(declare-const g:BucketNameValue String)

(assert (= g:PrincipalTypeValue "AssumedAgency"))
(assert (= g:ActionValue "listBucket"))
(assert (= g:EffectValue "Allow"))
(assert (= g:PrincipalIDValue "domain/233"))
(assert (= g:ConditionValue "(stringequals g:PrincipalType g:PrincipalTypeValue)"))
(assert (= g:BucketNameValue "compatible-special-format-0"))

(assert (and
  (= g:BucketName g:BucketNameValue)
  (exists ((g:Statement g:BucketPolicy))
    (and
      (exists ((g:Action g:Statement))
        (exists ((g:Effect g:Statement))
          (exists ((g:Principal g:Statement))
            (exists ((g:Condition g:Statement))
              (and
                (= g:Action g:ActionValue)
                (= g:Effect g:EffectValue)
                (= g:Principal g:PrincipalIDValue)
                (= g:Condition g:ConditionValue)
              )
            )
          )
        )
      )
    )
  )
))

(check-sat)
(get-model)